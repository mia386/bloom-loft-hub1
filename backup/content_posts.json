 {"id":"gbpd34c","platform":"ig","type":"Reel / Short","title":"Yin / restorative spotlight — \"cool down with us\"","description":"\"When your body is running hot — mentally and physically — yin yoga is the answer. Slow, grounded, cooling. This is what summer restoration looks like. See our schedule in bio and use the Summer Reset Pass.\"\nEducational, class-specific. Great summer angle — yin and restorative are peak summer classes. If there's a soundbath coming up, mention it here.","uses":"","assignee":"Brooklin","status":"assigned","week":3,"pipeline":{"go_live": "2026-06-17", "in_buffer": "2026-06-10", "caption_due": "", "owner_proof": "2026-06-10"},"tags":[],"blocker":"","approval":"","subtasks":[{"id": "yfaclel", "done": false, "text": "create design", "group": "Design"}],"created_at":"2026-05-27T16:03:07.136056+00:00","updated_at":"2026-05-27T16:03:07.136056+00:00"}, 
